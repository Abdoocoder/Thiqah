# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_xxxxx

# Convex Backend
VITE_CONVEX_URL=https://your-project.convex.cloud

# Clerk for Convex Auth (used in convex/auth.config.ts)
CLERK_FRONTEND_API_URL=https://your-clerk-domain.clerk.accounts.dev

# Firebase (optional, for analytics — if not set, analytics is disabled)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# WhatsApp (optional, defaults to 962779248914)
VITE_WHATSAPP_PHONE=
